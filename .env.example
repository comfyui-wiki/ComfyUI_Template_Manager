# GitHub OAuth App
# Create at: https://github.com/settings/developers
# Homepage URL: http://localhost:3000 (dev) or https://your-domain.vercel.app (prod)
# Callback URL: http://localhost:3000/api/auth/callback/github (dev)
#   or https://your-domain.vercel.app/api/auth/callback/github (prod)
# Scopes: read:user, user:email, public_repo

GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_random_secret_here

# NextAuth URL
# Dev:  http://localhost:3000/api/auth
# Prod: https://your-domain.vercel.app/api/auth
NEXTAUTH_URL=http://localhost:3000/api/auth

# Local repo mode (optional — read/write a local git clone instead of GitHub)
# WORKFLOW_TEMPLATES_MODE=local
# WORKFLOW_TEMPLATES_PATH=/path/to/workflow_templates
# WORKFLOW_TEMPLATES_COMPARE_REF=upstream/main

# Glossary sync from ComfyUI frontend locales (optional — for `pnpm glossary:sync`)
# Path must point at the locales directory and contain en/main.json
FRONTEND_LOCALES_PATH=/path/to/ComfyUI_frontend/src/locales
